# Copy this file to .env and fill in real values.
# .env is gitignored and must never be committed.

DISCORD_TOKEN=your-bot-token-here

# Discord server (guild) ID for development.
# Slash commands sync to this guild only — instant reflection during development.
# How to get: enable Developer Mode in Discord settings, right-click your test
# server icon, and choose "Copy Server ID".
DISCORD_GUILD_ID=your-test-server-id-here
